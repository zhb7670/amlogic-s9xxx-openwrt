#!/bin/sh /etc/rc.common
# Verysync init script

START=99
STOP=10

USE_PROCD=1
NAME=verysync

PROG=/usr/bin/verysync

validate_config_section() {
	uci_validate_section verysync config "${1}" \
		'enabled:bool:1' \
		'port:uinteger:8886' \
		'gui_listen:string:0.0.0.0' \
		'config_dir:string:/etc/verysync'
	
	return $?
}

start_instance() {
	local enabled port gui_listen config_dir
	
	validate_config_section "$1" || {
		echo "Validation failed"
		return 1
	}
	
	[ "$enabled" != "1" ] && {
		echo "Verysync is disabled"
		return 0
	}
	
	[ -d "$config_dir" ] || mkdir -p "$config_dir"
	
	procd_open_instance
	procd_set_param command "$PROG" -gui "${gui_listen}:${port}" -home "$config_dir"
	procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
	procd_set_param file "/etc/config/verysync"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
	
	echo "Verysync started on ${gui_listen}:${port}"
}

start_service() {
	config_load verysync
	config_foreach start_instance verysync
}

stop_service() {
	killall verysync 2>/dev/null
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "verysync"
	procd_add_validation validate_config_section
}